{
  "name": "deepspider",
  "version": "1.0.0-beta",
  "description": "智能爬虫工程平台 - MCP Server for Claude Code integration",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "agents/",
    "plugins/",
    "skills/",
    "requirements-crypto.txt",
    ".env.example"
  ],
  "bin": {
    "deepspider": "./bin/cli.js",
    "deepspider-mcp": "./src/mcp/server.js"
  },
  "scripts": {
    "mcp": "node src/mcp/server.js",
    "cli": "node bin/cli.js",
    "test": "node --test 'test/*.test.js'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "setup:crypto": "uv venv .venv --python 3.11 2>/dev/null || true && uv pip install -r requirements-crypto.txt",
    "postinstall": "patchright install chromium && npm rebuild isolated-vm 2>/dev/null || true",
    "prepare": "husky"
  },
  "keywords": [
    "crawler",
    "web-scraping",
    "javascript",
    "reverse-engineering",
    "deobfuscation",
    "captcha",
    "anti-detect",
    "automation"
  ],
  "author": "pony-ma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ma-pony/deepspider.git"
  },
  "homepage": "https://github.com/ma-pony/deepspider#readme",
  "bugs": {
    "url": "https://github.com/ma-pony/deepspider/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cycletls": "^2.0.5",
    "dotenv": "^17.2.3",
    "https-proxy-agent": "^7.0.6",
    "isolated-vm": "^6.0.2",
    "marked": "^17.0.1",
    "patchright": "^1.57.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1",
    "@opencode-ai/sdk": "1.3.13",
    "opencode-ai": "1.3.13",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  }
}
